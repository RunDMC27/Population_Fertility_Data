table Fact_UN_Population_metrics
	lineageTag: 3d76d5a6-3834-480f-a279-ea984c8dbd4d

	measure 'Fertility rate VAR_parallelperiod' =
			
			VAR FerPriorYear =
			    CALCULATE([Fertility Rate M/F], PARALLELPERIOD('Date_table'[Date], -12, MONTH))
			RETURN
			    ([Fertility Rate M/F] - FerPriorYear )
		lineageTag: aa4ba810-34b2-42d1-8aad-f7c745e9d38f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Population M/F' = calculate(sum(Fact_UN_Population_metrics[Total population by sex]),Fact_UN_Population_metrics[Sex]="Both sexes")
		lineageTag: 7b10f16d-945d-4f38-9248-0e8fa568cc06

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Population M/F Ages' = calculate(sum(Fact_UN_Population_metrics[Population by age and sex - broad age groups]),Fact_UN_Population_metrics[Sex]="Both sexes")
		lineageTag: c7525e04-de3a-4d00-a8a3-fb07eedd4750

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Fertility Rate M/F' = calculate(sum(Fact_UN_Population_metrics[Total fertility rate]),Fact_UN_Population_metrics[Sex]="Both sexes")
		lineageTag: 55cdc8fe-4f01-4fee-98e9-38a277dc3377

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Potential Support Ratio M/F' = calculate(sum(Fact_UN_Population_metrics[Potential support ratio]),Fact_UN_Population_metrics[Sex]="Both sexes")
		lineageTag: 717e447b-9594-456d-b7ef-a15f8133fdcb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Trend = IF([Fertility rate VAR_parallelperiod] > 0. UNICHAR(9650), UNICHAR(128315))
		lineageTag: b80fde65-90ac-45fa-aebd-ad3bfe26533e

	measure 'Population Latest' =
			
			VAR LatestYear =
			    MAXX(
			        FILTER(
			            ALL(Fact_UN_Population_metrics[EOYear]),
			            CALCULATE(
			                NOT ISBLANK(
			                    SUM(Fact_UN_Population_metrics[Total population by sex])),
			                Fact_UN_Population_metrics[EstimateMethod] = "Interpolation",
			                Fact_UN_Population_metrics[Sex] = "Both sexes")),
			        Fact_UN_Population_metrics[EOYear])
			RETURN
			CALCULATE(
			    SUM(Fact_UN_Population_metrics[Total population by sex]),
			    Fact_UN_Population_metrics[EstimateMethod] = "Interpolation",
			    Fact_UN_Population_metrics[Sex] = "Both sexes",
			    Fact_UN_Population_metrics[EOYear] = LatestYear)
		lineageTag: 5e5b1417-c3a1-4576-aee5-71d75a24b75f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Fertility Rate Latest' =
			
			VAR LatestYear =
			    MAXX(
			        FILTER(
			            ALL(Fact_UN_Population_metrics[EOYear]),
			            CALCULATE(
			                NOT ISBLANK(
			                    SUM(Fact_UN_Population_metrics[Total fertility rate])),
