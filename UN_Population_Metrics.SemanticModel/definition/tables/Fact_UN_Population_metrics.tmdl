			    Fact_UN_Population_metrics[Sex] = "Both sexes",
			    Fact_UN_Population_metrics[EOYear] = LatestYear)
		lineageTag: 86fd427c-eefa-42a4-abd0-694eb3015a24

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PSR (20-64/65+) Latest' =
			
			VAR LatestYear =
			    MAXX(
			        FILTER(
			            ALL(Fact_UN_Population_metrics[EOYear]),
			            CALCULATE(
			                NOT ISBLANK(
			                    SUM(Fact_UN_Population_metrics[Potential support ratio])),
			                Fact_UN_Population_metrics[EstimateMethod] = "Interpolation",
			                Fact_UN_Population_metrics[AgeLabel] = "[20-64/65+]",
			                Fact_UN_Population_metrics[Sex] = "Both sexes")),
