		lineageTag: b6a5f5e3-b02b-4049-bff7-0c0de0881605

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Title = CONCATENATE("United Nations Latest Population Data & 2050 Projections: ",SELECTEDVALUE(Fact_UN_Population_metrics[Location], "All Countries Selected"))
		lineageTag: 8cf89d62-2ae5-440a-b98d-27f620233711

	measure LatestDate =
			CALCULATE(
			    MAX(Fact_UN_Population_metrics[EOYear]),
			    REMOVEFILTERS(Fact_UN_Population_metrics[EOYear]))
		formatString: General Date
		lineageTag: cca4ef3f-7efb-4872-abaf-db8e3ba3df64

